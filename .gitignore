# ==============================================================================
# Emacs
# ==============================================================================
# configuration
emacs.d/etc/*
!emacs.d/etc/tempel/
!emacs.d/etc/tempel/templates.eld

# runtime data
emacs.d/var/*
!emacs.d/var/bookmark-default.el

# packages
emacs.d/elpa/

# ==============================================================================
# Shell
# ==============================================================================
# host-specific zsh overrides, not tracked.
zshrc.d/local.zsh
zshrc.d/local.env.zsh

# ==============================================================================
# Desktop / OS
# ==============================================================================
# GTK bookmarks are path-dependent.
config/linux/gtk-3.0/bookmarks
