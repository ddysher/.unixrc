#!/usr/bin/env zsh
##------------------------------------------------------------------------------
## ~/.unixrc/.zshrc - Main ZSH Configuration Entry Point
##
## This file serves as the main entry point for ZSH configuration.
## It loads modular configuration files from the config directory.
##
## Structure:
##   core/         - Shell options, PATH, completion, aliases
##   languages/    - Language runtime setups (Go, Python, Node)
##   tools/        - Optional external CLI tool integrations and plugins
##   local.zsh     - Local/host-specific overrides (not tracked in git)
##------------------------------------------------------------------------------

# Configuration directory
export ZSHRC_CONFIG_DIR="$HOME/.unixrc/zshrc.d"

# Helper function to safely source files
_source_if_exists() {
  [[ -r "$1" ]] && source "$1"
}


##------------------------------------------------------------------------------
## Core
##------------------------------------------------------------------------------

_source_if_exists "$ZSHRC_CONFIG_DIR/core/shell.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/core/path.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/core/completion.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/core/aliases.zsh"


##------------------------------------------------------------------------------
## Languages
##------------------------------------------------------------------------------

_source_if_exists "$ZSHRC_CONFIG_DIR/languages/golang.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/languages/python.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/languages/node.zsh"


##------------------------------------------------------------------------------
## Tools
##------------------------------------------------------------------------------

_source_if_exists "$ZSHRC_CONFIG_DIR/tools/starship.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/tools/fzf.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/tools/zoxide.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/tools/kubectl.zsh"
_source_if_exists "$ZSHRC_CONFIG_DIR/tools/zinit.zsh"


##------------------------------------------------------------------------------
## Local customizations (not tracked in git)
##------------------------------------------------------------------------------

_source_if_exists "$ZSHRC_CONFIG_DIR/local.zsh"

# Clean up helper function
unfunction _source_if_exists

# Compile zshrc for faster loading
if [[ ! -f ~/.zshrc.zwc || ~/.zshrc -nt ~/.zshrc.zwc ]]; then
  zcompile ~/.zshrc
fi
